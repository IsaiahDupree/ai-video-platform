      "content": {
        "type": "intro",
        "title": "5 signs your network is going cold",
        "hook_text": "Most people don't lose their network all at once. It happens one unanswered text at a time."
      }
    },
    {
      "id": "item_001",
      "type": "list_item",
      "duration_sec": 8,
      "start_time_sec": 5,
      "content": {
        "type": "list_item",
        "number": 1,
        "title": "You keep meaning to reply — but don't",
        "description": "The gap grows. They stop trying."
      }
    },
    {
      "id": "item_002",
      "type": "list_item",
      "duration_sec": 8,
      "start_time_sec": 13,
      "content": {
        "type": "list_item",
        "number": 2,
        "title": "You only reach out when you need something",
        "description": "They feel it. Everyone does."
      }
    },
    {
      "id": "item_003",
      "type": "list_item",
      "duration_sec": 8,
      "start_time_sec": 21,
      "content": {
        "type": "list_item",
        "number": 3,
        "title": "You forgot their last big win",
        "description": "No congrats. No follow-up. Just silence."
      }
    },
    {
      "id": "item_004",
      "type": "list_item",
      "duration_sec": 8,
      "start_time_sec": 29,
      "content": {
        "type": "list_item",
        "number": 4,
        "title": "It's been 3+ months and neither of you noticed",
        "description": "That's not a friendship. That's a contact."
      }
    },
    {
      "id": "item_005",
      "type": "list_item",
      "duration_sec": 8,
      "start_time_sec": 37,
      "content": {
        "type": "list_item",
        "number": 5,
        "title": "You'd feel awkward texting them right now",
